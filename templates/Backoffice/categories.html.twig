{% extends 'Backoffice/basebackoffice.html.twig' %}

{% block admin_content %}
<h2>Gestion des categories</h2>

<!-- Formulaire d'ajout -->
<form method="post" action="{{ path('admin_add_category') }}" class="mb-3 d-flex gap-2">
    <input type="text" name="name" placeholder="Nom de la categorie" class="form-control" required>
    <button class="btn btn-success">Ajouter</button>
</form>

<ul class="list-group">
{% for category in categories %}
    <li class="list-group-item d-flex justify-content-between align-items-center">
        {{ category.name }}

        {% if category.formations is empty %}
            <form method="post"
                  action="{{ path('admin_delete_category', {id: category.id}) }}"
                  onsubmit="return confirm('Confirmer la suppression ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                <button class="btn btn-danger btn-sm">Supprimer</button>
            </form>
        {% else %}
            <span class="badge bg-secondary">Utilisée</span>
        {% endif %}
    </li>
{% endfor %}
</ul>
{% endblock %}