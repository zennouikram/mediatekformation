{% extends 'Backoffice/basebackoffice.html.twig' %}

{% block admin_content %}

<h2>{{ playlist.id ? 'Modifier' : 'Ajouter' }} une playlist</h2>

{{ form_start(form) }}

<div class="mb-3">
    {{ form_label(form.name) }}
    {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Nom de la playlist'}}) }}
    {{ form_errors(form.name) }}
</div>

<div class="mb-3">
    {{ form_label(form.description) }}
    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Description (facultatif)'}}) }}
    {{ form_errors(form.description) }}
</div>

<button class="btn btn-success">{{ playlist.id ? 'Mettre à jour' : 'Ajouter' }}</button>

{{ form_end(form) }}

{% if playlist.id and playlist.formations is not empty %}
    <h3 class="mt-4">Formations liées :</h3>
    <ul class="list-group">
        {% for formation in playlist.formations %}
            <li class="list-group-item">{{ formation.title }}</li>
        {% endfor %}
    </ul>
{% endif %}

{% endblock %}