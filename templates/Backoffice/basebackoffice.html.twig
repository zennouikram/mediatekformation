{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-4">
    <h1>Back Office</h1>

    <nav class="mb-3">
        <a href="{{ path('admin_formations') }}" class="me-2">Formations</a>
        <a href="{{ path('admin_playlists') }}" class="me-2">Playlists</a>
        <a href="{{ path('admin_categories') }}" class="me-2">Catégories</a>
        <a href="{{ path('admin_logout') }}" class="text-danger">Déconnexion</a>
    </nav>

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% block admin_content %}{% endblock %}
</div>
{% endblock %}